{
  "name": "terminalcat",
  "version": "0.0.1",
  "private": true,
  "description": "Self-hosted web terminal",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p .",
    "start:prod": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "jose": "^6.2.3",
    "node-pty": "^1.0.0",
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
