# terminalcat env vars. Copy to .env and fill in real values.
# .env is gitignored. Production values usually come from systemd's
# Environment= / EnvironmentFile= directives, not this file (see
# deploy/terminalcat.service).

# ===== required =====

# Cloudflare Access team domain — the part before .cloudflareaccess.com.
# If your team URL is https://acme.cloudflareaccess.com, this is "acme".
# CF Zero Trust dashboard > Settings > General > Team domain.
CF_ACCESS_TEAM_DOMAIN=YOUR_TEAM_NAME

# Application Audience (AUD) tag for the Access app protecting this hostname.
# CF Zero Trust > Access > Applications > <your terminalcat app> > Overview.
# 64-char hex string, no dashes.
CF_ACCESS_AUD=YOUR_APPLICATION_AUD_TAG_HEX

# ===== recommended for production =====

# CSWSH defense-in-depth. Set to the canonical URL where users load the app
# (e.g. https://shell.example.com — same hostname as your CF Access app).
# WS upgrades whose Origin header doesn't match get a 403. Permissive on
# missing Origin (CLI tools / curl etc. still work; their JWT check is the
# real gate). Leave unset in dev where you may load over 127.0.0.1 / proxy.
# scripts/install.sh prompts for this; you can also set it later.
# ALLOWED_ORIGIN=https://shell.example.com

# ===== optional =====

# Log level: trace / debug / info / warn / error / fatal. Default: info.
# LOG_LEVEL=info

# If set, logs are also written to a daily-rotating file under this dir
# (in addition to stderr). The dir is created if missing.
# LOG_DIR=/var/log/terminalcat

# Optional output coalescing. Default 0 (off). If set to N (1..100), stdout
# from a session is buffered for N milliseconds before being flushed as one
# WS frame, instead of one frame per node-pty read. Trades that many ms of
# added latency for fewer frames per second under noisy redraw loads (htop,
# tui dashboards). Off keeps the headline keystroke RTT lowest. Try 5 if
# you hit a workload that visibly stutters; otherwise leave alone.
# OUTPUT_BATCH_MS=0
