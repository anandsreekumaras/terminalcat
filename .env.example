# terminalcat env vars. Copy to .env and fill in real values.
# .env is gitignored. Production values usually come from systemd's
# Environment= / EnvironmentFile= directives, not this file (see
# deploy/terminalcat.service).

# ===== required =====

# Cloudflare Access team domain — the part before .cloudflareaccess.com.
# If your team URL is https://acme.cloudflareaccess.com, this is "acme".
# CF Zero Trust dashboard > Settings > General > Team domain.
CF_ACCESS_TEAM_DOMAIN=YOUR_TEAM_NAME

# Application Audience (AUD) tag for the Access app protecting this hostname.
# CF Zero Trust > Access > Applications > <your terminalcat app> > Overview.
# 64-char hex string, no dashes.
CF_ACCESS_AUD=YOUR_APPLICATION_AUD_TAG_HEX

# ===== optional =====

# Log level: trace / debug / info / warn / error / fatal. Default: info.
# LOG_LEVEL=info

# If set, logs are also written to a daily-rotating file under this dir
# (in addition to stderr). The dir is created if missing.
# LOG_DIR=/var/log/terminalcat
